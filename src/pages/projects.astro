---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import { t } from '../i18n/ui';

const intro =
  "This is a collection of things I've built — usually to think with my hands rather than only on paper. Some began as quick prototypes during product discovery — a way to make a concept tangible, demonstrate it, and spark the first conversation and brainstorming around it. Others I built purely out of curiosity, to understand how something actually works. They're experiments, not polished products — but they're a big part of how I get from a vague idea to something concrete enough to react to. The code lives on GitHub.";

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title),
);

const toParagraphs = (s: string) =>
  s.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
---
<BaseLayout title={t('nav.projects')} description={intro}>
  <Container class="py-16">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-h1">{t('nav.projects')}</h1>
      <p class="mt-5 text-[1.05rem] leading-relaxed text-muted">{intro}</p>

      <ul class="mt-12 border-t border-line">
        {projects.map((p) => (
          <li data-accordion class="border-b border-line">
            <h2 class="m-0">
              <button
                id={`acc-btn-${p.id}`}
                type="button"
                aria-expanded="false"
                aria-controls={`acc-panel-${p.id}`}
                class="group flex w-full items-start justify-between gap-5 py-5 text-left"
              >
                <span class="min-w-0">
                  <span class="block font-display text-h3">{p.data.title}</span>
                  <span class="mt-1.5 block text-sm leading-relaxed text-muted">{p.data.shortDescription}</span>
                </span>
                <svg
                  class="mt-1 h-5 w-5 shrink-0 text-muted transition-transform duration-200 group-aria-expanded:rotate-180"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                >
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </button>
            </h2>

            <div id={`acc-panel-${p.id}`} role="region" aria-labelledby={`acc-btn-${p.id}`} data-panel class="accordion-panel">
              <div class="overflow-hidden">
                <div class="pb-7">
                  {p.data.image && (
                    <figure class="mb-6">
                      <img
                        src={p.data.image}
                        alt={p.data.imageAlt ?? p.data.title}
                        loading="lazy"
                        class="w-full rounded-[var(--radius-card)] border border-line"
                      />
                    </figure>
                  )}
                  <div class="max-w-prose space-y-4 leading-relaxed text-fg/90">
                    {toParagraphs(p.data.fullDescription).map((para) => <p>{para}</p>)}
                  </div>

                  {p.data.features && p.data.features.length > 0 && (
                    <div class="mt-6 max-w-prose">
                      <p class="text-xs font-semibold uppercase tracking-wider text-muted">What you can do</p>
                      <ul class="mt-3 space-y-2">
                        {p.data.features.map((f) => (
                          <li class="flex gap-2.5 leading-relaxed text-fg/90">
                            <span class="mt-0.5 text-accent" aria-hidden="true">→</span>
                            <span>{f}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  <div class="mt-6 flex flex-wrap gap-3">
                    <a
                      href={p.data.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 rounded-[var(--radius-pill)] border border-line bg-surface px-4 py-2 text-sm font-medium transition-colors hover:border-accent/50 hover:text-accent"
                    >
                      View on GitHub <span aria-hidden="true">↗</span>
                    </a>
                    {p.data.liveUrl && (
                      <a
                        href={p.data.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 rounded-[var(--radius-pill)] bg-accent px-4 py-2 text-sm font-medium text-on-accent transition-colors hover:bg-accent-hover"
                      >
                        Live site <span aria-hidden="true">↗</span>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </Container>
</BaseLayout>

<style>
  /* Animate height via grid-template-rows (smooth, content-agnostic). */
  .accordion-panel {
    display: grid;
    grid-template-rows: 1fr; /* expanded by default → content visible if JS is off */
    transition: grid-template-rows 260ms ease;
  }
  .accordion-panel[data-collapsed='true'] {
    grid-template-rows: 0fr;
  }
  @media (prefers-reduced-motion: reduce) {
    .accordion-panel {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-accordion]').forEach((root) => {
    const btn = root.querySelector('button');
    const panel = root.querySelector('[data-panel]') as HTMLElement | null;
    if (!btn || !panel) return;
    const setOpen = (open: boolean) => {
      btn.setAttribute('aria-expanded', String(open));
      panel.dataset.collapsed = String(!open);
    };
    // Collapse by default once JS is available.
    setOpen(false);
    btn.addEventListener('click', () => setOpen(btn.getAttribute('aria-expanded') !== 'true'));
  });
</script>
