---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import { topics } from '../../data/topics';

const allLessons = (await getCollection('lessons')).filter((l) => !l.data.draft && !l.id.endsWith('-ua'));
const idsByTopic = (slug: string) =>
  allLessons.filter((l) => l.id.split('/')[0] === slug).map((l) => l.id);

const intro =
  "I'm a product manager learning hardware from zero — in public. This is my working course on how connected products are built, pitched for a non-engineer who needs to follow the conversation and make good calls, not become an engineer. Work through it in order, or dip into a topic.";
---
<BaseLayout title="Learning Hub" description="A product manager learning hardware from zero, in public — a working course on how connected products are built.">
  <Container width="prose" class="py-16">
    <p class="text-sm font-medium uppercase tracking-widest text-accent">Learning Hub</p>
    <h1 class="mt-3 text-h1">Robotics &amp; Electronics for PMs</h1>
    <p class="mt-5 text-lead text-muted">{intro}</p>

    <ol class="mt-12 divide-y divide-line border-y border-line">
      {topics.map((t, i) => {
        const ids = idsByTopic(t.slug);
        const available = t.status === 'available' && ids.length > 0;
        const Tag = available ? 'a' : 'div';
        return (
          <li>
            <Tag
              href={available ? `/learn/${t.slug}` : undefined}
              class:list={[
                'group flex items-start gap-4 py-5',
                available ? '' : 'opacity-60',
              ]}
            >
              <span class="mt-0.5 w-6 shrink-0 font-display text-lg text-muted">{String(i + 1).padStart(2, '0')}</span>
              <span class="min-w-0 flex-1">
                <span class="flex flex-wrap items-center gap-2">
                  <span class={`font-display text-h3 ${available ? 'group-hover:text-accent' : ''}`}>{t.title}</span>
                  {!available && <span class="rounded-[var(--radius-pill)] bg-surface-2 px-2 py-0.5 text-[0.7rem] font-medium uppercase tracking-wider text-muted">Coming soon</span>}
                </span>
                <span class="mt-1 block text-sm leading-relaxed text-muted">{t.blurb}</span>
              </span>
              {available && <span class="mt-1 shrink-0 text-muted transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>}
            </Tag>
          </li>
        );
      })}
    </ol>
  </Container>
</BaseLayout>
