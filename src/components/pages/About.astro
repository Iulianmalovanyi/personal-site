---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../Container.astro';
import Button from '../Button.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { site } from '../../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// TODO: verify — placeholder bio to be replaced with the author's real copy.
// First-person, British English, honest and concise (BRIEF.md §4).
const bio: Record<typeof lang, string[]> = {
  en: [
    'I’m a product manager working at the intersection of software and hardware. For the last few years I’ve built clinical decision-support software used by 20,000+ clinicians — regulated digital health, where a wrong call has real consequences and patient safety comes before everything else.',
    'That work taught me to be rigorous: to care about evidence, quality systems, and the messy reality of how clinicians actually work. Now I’m extending that into connected, hardware-enabled products — learning the electronics, firmware, and lifecycle that turn software thinking into physical things.',
    'This site is where I do that learning in public — alongside notes on the books I read, the craft of product management, and growing as a person. Honest, in progress, and improving as I go.',
  ],
  uk: [
    'Я product manager, що працює на перетині software та hardware. Останні роки я будував clinical decision-support software, яким користуються 20 000+ клініцистів — regulated digital health, де помилка має реальні наслідки, а patient safety понад усе.',
    'Ця робота навчила мене бути ретельним: цінувати докази, quality systems і складну реальність того, як клініцисти працюють насправді. Тепер я переношу це у connected, hardware-enabled продукти — вивчаю electronics, firmware і lifecycle, що перетворюють продуктове мислення на фізичні речі.',
    'Цей сайт — місце, де я навчаюся у відкритому форматі: разом із нотатками про книги, які читаю, про ремесло product management і про розвиток як особистості. Чесно, у процесі та з постійним покращенням.',
  ],
};

// TODO: verify — placeholder skill groupings.
const skills: { heading: Record<typeof lang, string>; items: string[] }[] = [
  {
    heading: { en: 'Product', uk: 'Product' },
    items: ['Discovery & research', 'Roadmapping', 'Prioritisation', 'Stakeholder alignment'],
  },
  {
    heading: { en: 'Regulated & quality', uk: 'Regulated & quality' },
    items: ['Medical device (UKCA)', 'ISO 27001 / DCB0129', 'GDPR / HIPAA', 'QA mindset'],
  },
  {
    heading: { en: 'Hardware-curious', uk: 'Hardware-curious' },
    items: ['Electronics basics', 'Firmware & connectivity', 'Device → cloud → app', 'Lifecycle / EVT–PVT'],
  },
];
---
<BaseLayout title={t('about.title')}>
  <Container width="prose" class="py-16">
    <h1 class="text-h1">{t('about.title')}</h1>

    <div class="mt-8 space-y-5 text-[1.05rem] leading-relaxed">
      {bio[lang].map((para) => <p>{para}</p>)}
    </div>

    <!-- Skills -->
    <h2 class="mt-14 text-h3 border-b border-line pb-2">{t('about.skills.title')}</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {skills.map((group) => (
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-accent">{group.heading[lang]}</p>
          <ul class="mt-3 space-y-1.5 text-sm text-fg/85">
            {group.items.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <!-- CV + connect -->
    <div class="mt-14 flex flex-wrap items-center gap-3">
      {site.cvPath
        ? <Button href={site.cvPath} variant="primary">{t('about.cv.download')}</Button>
        : <Button variant="secondary" class="cursor-default opacity-70">{t('about.cv.soon')}</Button>}
      <Button href={site.linkedin} variant="ghost">{t('cta.connect')}</Button>
    </div>
  </Container>
</BaseLayout>
