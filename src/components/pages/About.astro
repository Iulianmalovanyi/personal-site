---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../Container.astro';
import Button from '../Button.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { site } from '../../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// First-person, British English, grounded in the author's CV (§4).
const bio: Record<typeof lang, string[]> = {
  en: [
    'I’m a product manager with over four years in healthcare and software. At C the Signs I lead an AI-driven cancer decision-support platform, integrated with NHS EHR systems and used daily by more than 20,000 clinicians across roughly 30% of UK practices — regulated digital health, where quality and patient safety come before everything else.',
    'I came to product through quality engineering. I started in QA — defining test strategy and automation from scratch — first on enterprise networking and monitoring products at SoftServe, then at C the Signs, where I was QA Lead before being promoted into product. That grounding in how systems actually break still shapes how I build them.',
    'Now I’m extending into connected, hardware-enabled products — learning electronics, firmware, and the hardware lifecycle from the ground up. This site is where I do that learning in public, alongside notes on the books I read, the craft of product management, and growing as a person. Honest, in progress, and improving as I go.',
  ],
  uk: [
    'Я product manager із понад чотирма роками досвіду в healthcare та software. У C the Signs я веду AI-driven платформу для cancer decision support, інтегровану з NHS EHR systems, якою щодня користуються понад 20 000 клініцистів приблизно у 30% практик Великої Британії — regulated digital health, де якість і patient safety понад усе.',
    'До продукту я прийшов через quality engineering. Починав у QA — будував test strategy та автоматизацію з нуля — спершу на enterprise networking та monitoring продуктах у SoftServe, потім у C the Signs, де був QA Lead до підвищення в product. Це розуміння того, як системи ламаються насправді, досі формує те, як я їх будую.',
    'Тепер я переходжу до connected, hardware-enabled продуктів — вивчаю electronics, firmware і hardware lifecycle з нуля. Цей сайт — місце, де я навчаюся у відкритому форматі: разом із нотатками про книги, які читаю, про ремесло product management і про розвиток як особистості. Чесно, у процесі та з постійним покращенням.',
  ],
};

const skills: { heading: Record<typeof lang, string>; items: string[] }[] = [
  {
    heading: { en: 'Product', uk: 'Product' },
    items: ['Product strategy', 'Roadmap planning', 'Backlog & prioritisation', 'Requirements management', 'Market & user research'],
  },
  {
    heading: { en: 'Leadership & delivery', uk: 'Leadership & delivery' },
    items: ['Cross-functional leadership', 'Stakeholder management', 'Release & go-to-market', 'Success-metrics tracking', 'Data-informed decisions'],
  },
  {
    heading: { en: 'Quality & tools', uk: 'Quality & tools' },
    items: ['Test strategy & automation', 'Scalable QA processes', 'Agile (Scrum)', 'Jira · Confluence · Figma'],
  },
];
---
<BaseLayout title={t('about.title')}>
  <Container width="prose" class="py-16">
    <h1 class="text-h1">{t('about.title')}</h1>

    <div class="mt-8 space-y-5 text-[1.05rem] leading-relaxed">
      {bio[lang].map((para) => <p>{para}</p>)}
    </div>

    <!-- Skills -->
    <h2 class="mt-14 text-h3 border-b border-line pb-2">{t('about.skills.title')}</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      {skills.map((group) => (
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-accent">{group.heading[lang]}</p>
          <ul class="mt-3 space-y-1.5 text-sm text-fg/85">
            {group.items.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <!-- CV + connect -->
    <div class="mt-14 flex flex-wrap items-center gap-3">
      {site.cvPath
        ? <Button href={site.cvPath} variant="primary">{t('about.cv.download')}</Button>
        : <Button variant="secondary" class="cursor-default opacity-70">{t('about.cv.soon')}</Button>}
      <Button href={site.linkedin} variant="ghost">{t('cta.connect')}</Button>
    </div>
  </Container>
</BaseLayout>
