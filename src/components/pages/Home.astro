---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../Container.astro';
import Button from '../Button.astro';
import { t } from '../../i18n/ui';
import { site } from '../../data/site';
---
<BaseLayout>
  <!-- Hero only. Text + portrait in golden-ratio columns (1.618 : 1). -->
  <Container class="flex min-h-[78vh] items-center py-16">
    <div class="grid w-full items-center gap-10 sm:gap-12 lg:grid-cols-[1.618fr_1fr]">
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <p class="text-sm font-medium uppercase tracking-widest text-accent">{t('site.role')}</p>
        <h1 class="mt-4 text-display">{t('site.title')}</h1>
        <p class="mt-6 max-w-xl text-lead text-muted">{t('site.tagline')}</p>
        <div class="mt-9 flex flex-wrap gap-3">
          <Button href="/projects" variant="primary">{t('cta.viewWork')}</Button>
          <Button href="/learn" variant="secondary">{t('cta.readHub')}</Button>
          <Button href={site.linkedin} variant="secondary">{t('cta.connect')}</Button>
        </div>
      </div>

      <!-- Portrait -->
      {site.photo && (
        <div class="order-1 lg:order-2">
          <img
            src={site.photo}
            alt="Iulian Malovanyi"
            width="400"
            height="400"
            class="mx-auto w-full max-w-[18rem] rounded-2xl border border-line object-cover shadow-[var(--shadow-soft)] lg:mx-0 lg:max-w-none"
          />
        </div>
      )}
    </div>
  </Container>
</BaseLayout>
