---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
const interactive = href
  ? 'transition-[transform,box-shadow,border-color] hover:-translate-y-0.5 hover:shadow-[var(--shadow-soft)] hover:border-accent/40'
  : '';
const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class={`block rounded-[var(--radius-card)] border border-line bg-surface p-6 ${interactive} ${className}`}
>
  <slot />
</Tag>
