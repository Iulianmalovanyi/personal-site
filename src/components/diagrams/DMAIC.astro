---
// The Six Sigma DMAIC improvement cycle.
interface Props { caption?: string; }
const { caption } = Astro.props;
const steps = [
  { k: 'D', name: 'Define', note: 'the problem & goal' },
  { k: 'M', name: 'Measure', note: 'how it performs now' },
  { k: 'A', name: 'Analyze', note: 'the root causes' },
  { k: 'I', name: 'Improve', note: 'and test the fix' },
  { k: 'C', name: 'Control', note: 'hold the gains' },
];
const w = 150;
const gap = 24;
const x = (i: number) => 20 + i * (w + gap);
---
<figure class="my-7">
  <div class="overflow-x-auto rounded-[var(--radius-card)] border border-line bg-surface p-4">
    <svg viewBox="0 0 890 210" class="block h-auto w-full min-w-[640px]" role="img"
      aria-label="DMAIC cycle: Define, Measure, Analyze, Improve, Control — then loop back for continuous improvement.">
      {steps.map((s, i) => (
        <g>
          <rect x={x(i)} y="50" width={w} height="70" rx="10" fill="var(--color-surface-2)" stroke="currentColor" stroke-width="1.5" class="text-accent" />
          <text x={x(i) + 16} y="92" class="text-accent" fill="currentColor" font-size="26" font-weight="800" font-family="var(--font-display)">{s.k}</text>
          <text x={x(i) + 44} y="82" class="text-fg" fill="currentColor" font-size="15" font-weight="700">{s.name}</text>
          <text x={x(i) + 44} y="101" class="text-muted" fill="currentColor" font-size="11">{s.note}</text>
          {i < steps.length - 1 && (
            <g class="text-muted">
              <line x1={x(i) + w} y1="85" x2={x(i) + w + gap - 6} y2="85" stroke="currentColor" stroke-width="2" />
              <path d={`M${x(i) + w + gap - 6} 85 l-9 -5 v10 z`} fill="currentColor" />
            </g>
          )}
        </g>
      ))}
      <!-- loop back: Control → Define -->
      <g class="text-muted">
        <path d={`M${x(4) + w / 2} 120 V 165 H ${x(0) + w / 2} V 120`} fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5 4" />
        <path d={`M${x(0) + w / 2} 124 l-5 10 h10 z`} fill="currentColor" />
        <text x="445" y="183" text-anchor="middle" class="text-muted" fill="currentColor" font-size="11.5">repeat — continuous improvement</text>
      </g>
    </svg>
  </div>
  {caption && <figcaption class="mt-2 text-sm text-muted">{caption}</figcaption>}
</figure>
