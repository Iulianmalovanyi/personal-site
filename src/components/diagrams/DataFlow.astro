---
// device → cloud → app round trip (BRIEF.md §7). Forward = data up; return = command/OTA down.
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
const nodes = [
  { x: 70, title: 'Device', sub: 'sensor · MCU · firmware' },
  { x: 335, title: 'Cloud', sub: 'state · device mgmt' },
  { x: 600, title: 'App', sub: 'mobile / web' },
];
const w = 150;
const cx = (n: { x: number }) => n.x + w / 2;
---
<figure class="my-7">
  <div class="overflow-x-auto rounded-[var(--radius-card)] border border-line bg-surface p-4">
    <svg viewBox="0 0 820 230" class="block h-auto w-full min-w-[560px]" role="img"
      aria-label="Data flows up from the device over connectivity to the cloud, then via an API to the app; commands and OTA updates flow back down the same path.">
      <!-- forward arrows (data up) -->
      <g class="text-accent">
        <line x1={nodes[0].x + w} y1="70" x2={nodes[1].x - 6} y2="70" stroke="currentColor" stroke-width="2" />
        <path d={`M${nodes[1].x - 6} 70 l-10 -5 v10 z`} fill="currentColor" />
        <line x1={nodes[1].x + w} y1="70" x2={nodes[2].x - 6} y2="70" stroke="currentColor" stroke-width="2" />
        <path d={`M${nodes[2].x - 6} 70 l-10 -5 v10 z`} fill="currentColor" />
        <text x={(nodes[0].x + w + nodes[1].x) / 2} y="58" text-anchor="middle" fill="currentColor" font-size="11.5" font-weight="600">Wi-Fi / BLE / cellular · MQTT</text>
        <text x={(nodes[1].x + w + nodes[2].x) / 2} y="58" text-anchor="middle" fill="currentColor" font-size="11.5" font-weight="600">API</text>
      </g>

      <!-- nodes -->
      {nodes.map((n) => (
        <g>
          <rect x={n.x} y="84" width={w} height="62" rx="10" class="text-line" fill="var(--color-surface-2)" stroke="currentColor" stroke-width="1.5" />
          <text x={cx(n)} y="114" text-anchor="middle" class="text-fg" fill="currentColor" font-size="16" font-weight="700">{n.title}</text>
          <text x={cx(n)} y="132" text-anchor="middle" class="text-muted" fill="currentColor" font-size="11">{n.sub}</text>
        </g>
      ))}

      <!-- return arrows (command / OTA down) -->
      <g class="text-muted">
        <line x1={nodes[2].x} y1="172" x2={nodes[1].x + w + 6} y2="172" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5 4" />
        <path d={`M${nodes[1].x + w + 6} 172 l10 -5 v10 z`} fill="currentColor" />
        <line x1={nodes[1].x} y1="172" x2={nodes[0].x + w + 6} y2="172" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5 4" />
        <path d={`M${nodes[0].x + w + 6} 172 l10 -5 v10 z`} fill="currentColor" />
        <text x={(nodes[0].x + w + nodes[2].x) / 2} y="196" text-anchor="middle" fill="currentColor" font-size="11.5" font-weight="600">command / OTA update</text>
      </g>
    </svg>
  </div>
  {caption && <figcaption class="mt-2 text-sm text-muted">{caption}</figcaption>}
</figure>
