---
// "Two clocks": software/cloud iterates fast (OTA); hardware changes slowly (revs).
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
const softwareTicks = [80, 175, 270, 365, 460, 555, 650, 745, 840];
const hardwareTicks = [
  { x: 150, label: 'rev A' },
  { x: 470, label: 'rev B' },
  { x: 800, label: 'rev C' },
];
---
<figure class="my-7">
  <div class="overflow-x-auto rounded-[var(--radius-card)] border border-line bg-surface p-4">
    <svg viewBox="0 0 920 200" class="block h-auto w-full min-w-[560px]" role="img"
      aria-label="Two clocks: software updates over the air frequently, while hardware changes only at occasional revisions.">
      <!-- software lane -->
      <text x="20" y="44" fill="currentColor" class="text-fg" font-size="14" font-weight="700">Software / cloud</text>
      <text x="20" y="62" fill="currentColor" class="text-muted" font-size="12">over-the-air, weekly</text>
      <g class="text-accent">
        <line x1="40" y1="84" x2="880" y2="84" stroke="currentColor" stroke-width="2" />
        {softwareTicks.map((tx) => <circle cx={tx} cy="84" r="5" fill="currentColor" />)}
      </g>

      <!-- hardware lane -->
      <text x="20" y="140" fill="currentColor" class="text-fg" font-size="14" font-weight="700">Hardware</text>
      <text x="20" y="158" fill="currentColor" class="text-muted" font-size="12">revisions, 1–3 years apart</text>
      <g class="text-line"><line x1="40" y1="180" x2="880" y2="180" stroke="currentColor" stroke-width="2" /></g>
      {hardwareTicks.map((t) => (
        <g class="text-fg">
          <rect x={t.x - 7} y="172" width="14" height="16" rx="3" fill="currentColor" />
          <text x={t.x} y="166" text-anchor="middle" fill="currentColor" class="text-muted" font-size="12" font-weight="600">{t.label}</text>
        </g>
      ))}
    </svg>
  </div>
  {caption && <figcaption class="mt-2 text-sm text-muted">{caption}</figcaption>}
</figure>
